# Copy this file to .env and fill in real values.
# .env is ignored by git; .env.copy is safe to commit.

# # Azure OpenAI GPT-4.1
# # Final URL becomes:
# # https://your-resource.openai.azure.com/openai/deployments/gpt-4.1-sit/chat/completions?api-version=2025-01-01-preview
# AZURE_OPENAI_ENDPOINT=https://your-azure-openai-resource.openai.azure.com
# AZURE_OPENAI_API_KEY=replace-with-your-key
# AZURE_OPENAI_API_VERSION=2025-01-01-preview
# AZURE_OPENAI_GPT41_DEPLOYMENT=gpt-4.1

# # Azure AI Foundry DeepSeek-V4-Flash
# # Final URL becomes:
# # https://your-resource.services.ai.azure.com/models/chat/completions?api-version=2024-05-01-preview
# AZURE_FOUNDRY_ENDPOINT=https://your-foundry-resource.services.ai.azure.com/models
# AZURE_FOUNDRY_API_KEY=replace-with-your-key
# AZURE_FOUNDRY_API_VERSION=2024-05-01-preview
# AZURE_FOUNDRY_DEEPSEEK_V4_FLASH_MODEL=DeepSeek-V4-Flash

# # Azure AI Foundry GPT-5.4 Mini through the OpenAI Responses API.
# # Final URL becomes:
# # https://your-resource.cognitiveservices.azure.com/openai/responses?api-version=2025-04-01-preview
# AZURE_FOUNDRY_ENDPOINT_OPENAI=https://your-resource.cognitiveservices.azure.com
# AZURE_FOUNDRY_API_VERSION_OPENAI=2025-04-01-preview
# AZURE_FOUNDRY_GPT54_MINI_MODEL_OPENAI=gpt-5.4-mini
# AZURE_FOUNDRY_GPT54_MINI_MODEL_OPENAI_priority=gpt-5.4-mini-priority

# # Azure AI Korera Central Foundry DeepSeek-V4-Flash
# AZURE_FOUNDRY_ENDPOINT_KOREA_CENTRAL=https://your-foundry-resource.services.ai.azure.com/models
# AZURE_FOUNDRY_API_KEY_KOREA_CENTRAL=replace-with-your-key
# AZURE_FOUNDRY_API_VERSION_KOREA_CENTRAL=2024-05-01-preview
# AZURE_FOUNDRY_DEEPSEEK_V4_FLASH_MODEL_KOREA_CENTRAL=DeepSeek-V4-Flash


# # Alibaba Cloud OpenAI-compatible endpoint
# ALIBABA_CLOUD_COMPATIBLE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# ALIBABA_CLOUD_API_KEY=replace-with-your-key
# ALIBABA_DEEPSEEK_V4_FLASH_MODEL=deepseek-v4-flash

# Aliyun OpenAI-compatible endpoint
ALIYUN_COMPATIBLE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
ALIYUN_API_KEY=replace-with-your-key
ALIYUN_DEEPSEEK_V4_FLASH_MODEL=deepseek-v4-flash